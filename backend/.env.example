# Copia este archivo como .env y ajusta los valores
PORT=4000
# Clave secreta para firmar los tokens JWT. CAMBIALA en produccion.
JWT_SECRET=box_motivacion_crossfit_secret_cambia_esto
# Tiempo de expiracion del token
JWT_EXPIRES=8h
# Origen permitido para CORS (el frontend). Usa * para desarrollo local.
CORS_ORIGIN=*

# --- Base de datos ---
# LOCAL: deja estas dos vacias y se usara un archivo SQLite local (data/box.db).
# TURSO (nube, gratis y persistente): pega aqui los datos de tu base.
#   1) Crea una cuenta en https://turso.tech
#   2) Crea una base:        turso db create box-motivacion
#   3) URL:                  turso db show box-motivacion --url
#   4) Token:                turso db tokens create box-motivacion
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
